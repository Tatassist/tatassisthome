---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { articleCTAs } from '../data/site';

interface Props {
  title: string;
  description: string;
  category: string;
  quickTake: string;
  primaryCTA: string;
  secondaryCTA?: string;
  ctaBridge: string;
  publishDate: string;
  updatedDate?: string;
  faqs?: { question: string; answer: string }[];
  relatedArticles?: string[];
}

const {
  title,
  description,
  category,
  quickTake,
  primaryCTA,
  secondaryCTA,
  ctaBridge,
  publishDate,
  updatedDate,
  faqs,
  relatedArticles,
} = Astro.props;

const categoryLabels: Record<string, string> = {
  'pricing': 'Pricing',
  'deposits': 'Deposits',
  'client-qualification': 'Client Qualification',
  'professional-systems': 'Professional Systems',
  'coverups': 'Coverups & Premium Work',
};

const primary = articleCTAs[primaryCTA as keyof typeof articleCTAs];
const secondary = secondaryCTA ? articleCTAs[secondaryCTA as keyof typeof articleCTAs] : undefined;
const articleUrl = new URL(Astro.url.pathname, Astro.site);
const articleStructuredData: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description,
    author: [
      {
        '@type': 'Person',
        name: 'Joker',
      },
      {
        '@type': 'Person',
        name: 'Linda',
      },
    ],
    publisher: {
      '@type': 'Organization',
      name: 'Tatassist',
      logo: {
        '@type': 'ImageObject',
        url: new URL('/logo.jpg', Astro.site),
      },
    },
    datePublished: publishDate,
    ...(updatedDate ? { dateModified: updatedDate } : {}),
    mainEntityOfPage: articleUrl,
    image: new URL('/logo.jpg', Astro.site),
    articleSection: categoryLabels[category] || category,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Resources',
        item: new URL('/resources', Astro.site),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: categoryLabels[category] || category,
        item: new URL(`/resources/${category}`, Astro.site),
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: title,
        item: articleUrl,
      },
    ],
  },
];

if (faqs && faqs.length > 0) {
  articleStructuredData.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(({ question, answer }) => ({
      '@type': 'Question',
      name: question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: answer,
      },
    })),
  });
}
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  structuredData={articleStructuredData}
  pageType="resource_article"
>
  <Nav slot="header" />

  <article class="pt-28 sm:pt-36 pb-16 sm:pb-24">
    <!-- Article Header -->
    <header class="max-w-3xl mx-auto px-4 sm:px-6 mb-12">
      <div class="mb-6">
        <a
          href={`/resources/${category}`}
          class="text-brand-gold text-sm font-semibold uppercase tracking-wider hover:text-brand-gold/80 transition-colors"
          data-track="true"
          data-track-event="tatassist_nav_click"
          data-track-label={categoryLabels[category] || category}
          data-track-location="article_category_link"
          data-track-type="navigation"
          data-track-destination={`/resources/${category}`}
        >
          {categoryLabels[category] || category}
        </a>
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-brand-cream leading-tight mb-6">
        {title}
      </h1>
      <p class="text-lg sm:text-xl text-brand-text-muted leading-relaxed mb-6">
        {description}
      </p>
      <div class="flex items-center gap-4 text-sm text-brand-text-muted/60">
        <span>Joker & Linda, Tatassist</span>
        <span>&middot;</span>
        <time>{publishDate}</time>
        {updatedDate && (
          <>
            <span>&middot;</span>
            <span>Updated {updatedDate}</span>
          </>
        )}
      </div>
    </header>

    <!-- Quick Take -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 mb-12">
      <div class="bg-brand-dark-lighter border-l-4 border-brand-gold rounded-r-xl p-6">
        <p class="text-sm font-semibold text-brand-gold uppercase tracking-wider mb-2">Quick Take</p>
        <p class="text-brand-cream leading-relaxed">{quickTake}</p>
      </div>
    </div>

    <!-- Article Body -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 prose-tatassist">
      <slot />
    </div>

    <!-- CTA Section -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 mt-16">
      <div class="bg-brand-dark-lighter border border-white/10 rounded-xl p-8 sm:p-10">
        <p class="text-brand-text-muted text-lg leading-relaxed mb-6">{ctaBridge}</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={primary.href}
            class="inline-flex items-center justify-center px-8 py-3.5 bg-brand-red hover:bg-brand-red-dark text-white font-semibold rounded-lg transition-colors"
            data-track="true"
            data-track-event="tatassist_cta_click"
            data-track-label={primary.label}
            data-track-location="resource_article_cta"
            data-track-type="primary"
            data-track-destination={primary.href}
          >
            {primary.label}
          </a>
          {secondary && (
            <a
              href={secondary.href}
              class="inline-flex items-center justify-center px-8 py-3.5 border border-brand-cream/30 text-brand-cream hover:bg-white/5 font-medium rounded-lg transition-colors"
              data-track="true"
              data-track-event="tatassist_cta_click"
              data-track-label={secondary.label}
              data-track-location="resource_article_cta"
              data-track-type="secondary"
              data-track-destination={secondary.href}
            >
              {secondary.label}
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- FAQs -->
    {faqs && faqs.length > 0 && (
      <div class="max-w-3xl mx-auto px-4 sm:px-6 mt-16">
        <h2 class="text-2xl font-heading font-bold text-brand-cream mb-8">Frequently Asked Questions</h2>
        <div class="space-y-6">
          {faqs.map(({ question, answer }) => (
            <div class="border-b border-white/10 pb-6">
              <h3 class="text-lg font-heading font-bold text-brand-cream mb-2">{question}</h3>
              <p class="text-brand-text-muted leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Author Box -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 mt-16">
      <div class="bg-brand-dark-lighter border border-white/10 rounded-xl p-6 sm:p-8">
        <p class="text-sm font-semibold text-brand-gold uppercase tracking-wider mb-3">About the Authors</p>
        <p class="text-brand-text-muted leading-relaxed">
          Joker and Linda have been tattooing for over 18 years each. They've built Tatassist from real industry experience — surviving the 2008 crash, COVID, and today's slowdown — to help other artists build stronger, more profitable tattoo businesses through better pricing, deposits, and professional systems.
        </p>
      </div>
    </div>

    <!-- Related Resources -->
    {relatedArticles && relatedArticles.length > 0 && (
      <div class="max-w-3xl mx-auto px-4 sm:px-6 mt-16">
        <h2 class="text-2xl font-heading font-bold text-brand-cream mb-6">Related Resources</h2>
        <div class="space-y-3">
          {relatedArticles.map((slug) => (
            <a
              href={`/resources/${slug}`}
              class="block bg-brand-dark-lighter border border-white/10 hover:border-brand-gold/30 rounded-xl p-5 transition-colors"
              data-track="true"
              data-track-event="tatassist_related_article_click"
              data-track-label={slug}
              data-track-location="related_resources"
              data-track-type="internal_article"
              data-track-destination={`/resources/${slug}`}
            >
              <span class="text-brand-cream hover:text-brand-gold font-medium">{slug}</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>

  <!-- Back to Resources -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 pb-16">
    <a
      href="/resources"
      class="text-brand-gold hover:text-brand-gold/80 text-sm font-medium transition-colors"
      data-track="true"
      data-track-event="tatassist_nav_click"
      data-track-label="Back to all resources"
      data-track-location="article_footer"
      data-track-type="navigation"
      data-track-destination="/resources"
    >
      &larr; Back to all resources
    </a>
  </div>

  <Footer slot="footer" />
</BaseLayout>

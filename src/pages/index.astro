---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { artistSystemsConfig } from '../data/artist-systems';

const clientFlowVault = [
  'Client-flow audit + map',
  'Inquiry form field map',
  'Fit decision guide',
  'Eight modular client messages',
  'Three policy decision worksheets',
  'Two simple trackers',
];

const monthlyBookingDrop = [
  '14-day campaign plan',
  'Books-open copy',
  'Six editable layouts',
  'Two short-video prompts',
  'Email + DM messages',
  'Results tracker',
];

const flowSteps = ['Inquiry', 'Qualify', 'Estimate + Deposit', 'Book'];

const installationSteps = [
  {
    number: '01',
    title: 'Map the leak',
    description:
      'Audit your inquiry-to-appointment path and identify the three biggest friction points.',
  },
  {
    number: '02',
    title: 'Configure the system',
    description:
      'Adapt the inquiry fields, replies, deposit decisions, and boundaries to your business.',
  },
  {
    number: '03',
    title: 'Put it in motion',
    description:
      'Install the live path, run the first booking campaign, and measure what changes.',
  },
];

const whatItIs = [
  'Editable building blocks for your voice and shop rules',
  'A reusable client-flow system',
  'One complete booking campaign each month',
  'Implementation walkthroughs and shop-floor support',
];

const whatItIsNot = [
  'A replacement for your calendar, inbox, or booking software',
  'Contracts, consent forms, legal advice, or medical guidance',
  'A guarantee of appointments or income',
  'Dependent on the Tatassist Pricing Calculator',
];

const depositSteps = [
  'Estimate before design',
  'Quote with confidence',
  'Take a proportional deposit',
];

const founderTimeline = [
  { year: '2008', label: 'First downturn' },
  { year: '2020', label: 'COVID' },
  { year: 'Now', label: 'Another slowdown' },
];

const launchResources = [
  {
    title: "How I 10x'd My Deposits in One Month",
    category: 'Deposits',
    href: '/resources/deposits/10x-deposits',
  },
  {
    title: 'The Real Cost of Bad-Fit Tattoo Clients',
    category: 'Client flow',
    href: '/resources/client-qualification/cost-of-bad-fit-clients',
  },
  {
    title: 'Professional Systems Make Premium Pricing Believable',
    category: 'Systems',
    href: '/resources/professional-systems/premium-pricing',
  },
];
---

<BaseLayout
  title="Tatassist Artist Systems for Working Tattoo Artists"
  description="Install a cleaner path from tattoo inquiry to paid appointment, then run one ready-to-use booking campaign each month with Tatassist Artist Systems."
  ogImage="/og/tatassist-artist-systems-home.png"
  pageType="artist_systems_home"
>
  <Nav slot="header" />

  <div class="launch-page">
    <section class="print-dark launch-hero">
      <div class="launch-shell hero-grid">
        <div class="hero-copy">
          <h1>Stop rebuilding your booking process in DMs every week.</h1>
          <p class="hero-support">
            Install a cleaner path from inquiry to paid appointment, then use a ready-to-run booking
            campaign when your calendar needs attention.
          </p>

          <div class="action-row">
            <a
              class="launch-button launch-button-primary"
              href="/artist-systems/qualify"
              data-track="true"
              data-track-event="tatassist_qualifier_started"
              data-track-label="Check founding fit"
              data-track-location="home_launch_hero"
              data-track-type="primary"
              data-track-destination="/artist-systems/qualify"
            >
              Check founding fit
              <svg aria-hidden="true" viewBox="0 0 28 18">
                <path d="M1 9h23M17 2l7 7-7 7" />
              </svg>
            </a>
            <a class="launch-link launch-link-blue" href="#included">
              See what is included
              <svg aria-hidden="true" viewBox="0 0 28 18">
                <path d="M1 9h23M17 2l7 7-7 7" />
              </svg>
            </a>
          </div>

          <div class="credibility-line" aria-label="Built by working tattoo artists with more than 18 years each in the industry since 2008">
            <span>By working tattoo artists</span>
            <span>18+ years each</span>
            <span>Since 2008</span>
          </div>
        </div>

        <aside class="founding-panel" aria-label="Founding offer details">
          <p class="founding-title">Founding <strong>{artistSystemsConfig.foundingCapacity}</strong></p>
          <dl>
            <div>
              <dt>Refundable reservation</dt>
              <dd>${artistSystemsConfig.foundingPrice}</dd>
            </div>
            <div>
              <dt>Founding membership if activated</dt>
              <dd>${artistSystemsConfig.foundingPrice}/month</dd>
            </div>
            <div>
              <dt>Access</dt>
              <dd>{artistSystemsConfig.foundingAccessDate}</dd>
            </div>
            <div>
              <dt>Eligibility</dt>
              <dd>U.S. working artists</dd>
            </div>
            <div>
              <dt>Planned reservation window</dt>
              <dd>July 24–31</dd>
            </div>
          </dl>
        </aside>

        <div class="flow-line" aria-label="Inquiry to booked appointment path">
          {flowSteps.map((step, index) => (
            <>
              <span class:list={['flow-step', `flow-step-${index + 1}`]}>{step}</span>
              {index < flowSteps.length - 1 && (
                <svg class="flow-arrow" aria-hidden="true" viewBox="0 0 72 24">
                  <path d="M1 12h64M54 3l11 9-11 9" />
                </svg>
              )}
            </>
          ))}
        </div>
      </div>
    </section>

    <section id="included" class="paper-section product-scope scroll-target">
      <div class="launch-shell">
        <div class="section-intro section-intro-wide">
          <h2>One working client path. One complete booking push.</h2>
          <p>The founding release stays focused on the moments that cost working artists time every week.</p>
        </div>

        <div class="engine-grid">
          <article class="product-engine engine-vault">
            <header>
              <p class="section-label label-blue">The Client Flow Vault</p>
              <h3>A reusable system for the path from inquiry to paid appointment.</h3>
            </header>
            <ol class="ruled-list">
              {clientFlowVault.map((item, index) => (
                <li><span>{String(index + 1).padStart(2, '0')}</span>{item}</li>
              ))}
            </ol>
          </article>

          <article class="product-engine engine-drop">
            <header>
              <p class="section-label label-red">The Monthly Booking Drop</p>
              <h3>One complete campaign for a timely booking outcome.</h3>
            </header>
            <p class="campaign-theme">Books Open Without the DM Pileup</p>
            <ol class="ruled-list">
              {monthlyBookingDrop.map((item, index) => (
                <li><span>{String(index + 1).padStart(2, '0')}</span>{item}</li>
              ))}
            </ol>
          </article>
        </div>

        <div class="engine-bridge" aria-label="How the two Artist Systems parts work together">
          <span>Cleaner client flow</span>
          <svg aria-hidden="true" viewBox="0 0 72 24"><path d="M1 12h64M54 3l11 9-11 9" /></svg>
          <span>Ready campaign</span>
          <svg aria-hidden="true" viewBox="0 0 72 24"><path d="M1 12h64M54 3l11 9-11 9" /></svg>
          <span>Implement + measure</span>
        </div>
        <p class="support-rule">
          Works beside the forms, DMs, email, calendar, or booking software you already use.
        </p>
      </div>
    </section>

    <section id="how-it-installs" class="print-dark installation-section scroll-target">
      <div class="launch-shell">
        <div class="section-intro section-intro-wide section-intro-dark">
          <h2>Built to be <span class="red-ink">installed</span>, not admired in <span class="blue-ink">Downloads</span>.</h2>
          <p>The first hour is about putting one cleaner client path into the tools you already use.</p>
        </div>

        <ol class="installation-grid">
          {installationSteps.map((step, index) => (
            <li class:list={['installation-step', `installation-step-${index + 1}`]}>
              <div class="step-heading">
                <span>{step.number}</span>
                <h3>{step.title}</h3>
              </div>
              <p>{step.description}</p>
              {index < installationSteps.length - 1 && (
                <svg aria-hidden="true" viewBox="0 0 120 24"><path d="M1 12h112M102 3l11 9-11 9" /></svg>
              )}
            </li>
          ))}
        </ol>

        <p class="activation-statement">
          Activation = <span>installed in a live workflow</span>, not just downloaded.
        </p>
        <div class="centered-action">
          <a
            class="launch-button launch-button-primary"
            href="/artist-systems/qualify"
            data-track="true"
            data-track-event="tatassist_qualifier_started"
            data-track-label="Check founding fit"
            data-track-location="home_installation"
            data-track-type="primary"
            data-track-destination="/artist-systems/qualify"
          >
            Check founding fit
            <svg aria-hidden="true" viewBox="0 0 28 18"><path d="M1 9h23M17 2l7 7-7 7" /></svg>
          </a>
          <p>About one minute. Your answers stay in your browser.</p>
        </div>
      </div>
    </section>

    <section id="what-it-is" class="paper-section comparison-section scroll-target">
      <div class="launch-shell">
        <div class="section-intro section-intro-wide section-intro-centered">
          <h2>This is <span class="red-ink">not</span> another booking app.</h2>
          <p>
            Artist Systems supplies tattoo-specific decisions, language, and implementation beside the
            tools you already use.
          </p>
        </div>

        <div class="comparison-grid">
          <article class="comparison-column comparison-is">
            <h3>What it is</h3>
            <ul>
              {whatItIs.map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="comparison-column comparison-not">
            <h3>What it is not</h3>
            <ul>
              {whatItIsNot.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>

        <a class="comparison-link" href="/toolkit">
          Read straight answers
          <svg aria-hidden="true" viewBox="0 0 28 18"><path d="M1 9h23M17 2l7 7-7 7" /></svg>
        </a>
      </div>
    </section>

    <section id="deposit-proof" class="paper-section deposit-proof scroll-target">
      <div class="launch-shell deposit-grid">
        <div class="deposit-story">
          <p class="section-label label-blue">A shop-floor result</p>
          <h2>Clearer estimates changed what we could ask for upfront.</h2>
          <p>
            Pricing before design helped us move from token deposits to meaningful proportional deposits
            and grow the amount collected 10x in one month.
          </p>
          <div class="action-row action-row-dark">
            <a
              class="launch-button launch-button-primary"
              href="/calculator"
              data-track="true"
              data-track-event="tatassist_cta_click"
              data-track-label="See the Pricing Calculator"
              data-track-location="home_deposit_proof"
              data-track-type="supporting"
              data-track-destination="/calculator"
            >
              See the Pricing Calculator
              <svg aria-hidden="true" viewBox="0 0 28 18"><path d="M1 9h23M17 2l7 7-7 7" /></svg>
            </a>
            <a class="launch-link launch-link-blue dark-link" href="/resources/deposits/10x-deposits">
              Read the 10x deposit story
              <svg aria-hidden="true" viewBox="0 0 28 18"><path d="M1 9h23M17 2l7 7-7 7" /></svg>
            </a>
          </div>
        </div>

        <div class="deposit-result">
          <p class="deposit-number">10x</p>
          <p class="deposit-caption">Deposit growth in one month</p>
          <div class="deposit-path" aria-label="Estimate before design, quote with confidence, take a proportional deposit">
            {depositSteps.map((step, index) => (
              <>
                <span>{step}</span>
                {index < depositSteps.length - 1 && (
                  <svg aria-hidden="true" viewBox="0 0 52 18"><path d="M1 9h45M37 2l8 7-8 7" /></svg>
                )}
              </>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="founder-proof" class="print-dark founder-proof scroll-target">
      <div class="launch-shell founder-grid">
        <div class="founder-copy">
          <h2>Built by tattoo artists, not business coaches.</h2>
          <p>
            We have each spent more than 18 years tattooing through hard seasons. What changed our business
            was not more hustle. It was better structure.
          </p>
          <a class="launch-link launch-link-blue" href="/about">
            Read our story
            <svg aria-hidden="true" viewBox="0 0 28 18"><path d="M1 9h23M17 2l7 7-7 7" /></svg>
          </a>
        </div>

        <div class="years-proof" aria-label="More than 18 years each in tattooing">
          <strong>18+</strong>
          <span>Years each</span>
          <em>in tattooing</em>
        </div>

        <figure class="brand-print">
          <img src="/logo.jpg" alt="Tatassist — By Artists, For Artists, est 2008" />
        </figure>

        <ol class="founder-timeline">
          {founderTimeline.map((item, index) => (
            <li class:list={[`timeline-item-${index + 1}`]}>
              <strong>{item.year}</strong>
              <span>{item.label}</span>
            </li>
          ))}
        </ol>
        <p class="founder-lesson">
          The lesson stayed the same: talent matters. <span>Structure decides whether the business can breathe.</span>
        </p>
      </div>
    </section>

    <section id="launch-resources" class="paper-section launch-reading scroll-target">
      <div class="launch-shell">
        <div class="section-intro section-intro-wide section-intro-centered">
          <h2>Understand the leak. Then install the fix.</h2>
          <p>
            Our free resources explain why stronger pricing, deposits, and client flow matter. Artist Systems
            contains the implementation.
          </p>
        </div>

        <div class="resource-rail">
          {launchResources.map((resource, index) => (
            <a
              href={resource.href}
              class:list={['resource-row', `resource-row-${index + 1}`]}
              data-track="true"
              data-track-event="tatassist_resource_click"
              data-track-label={resource.title}
              data-track-location="home_launch_resources"
              data-track-type="content"
              data-track-destination={resource.href}
            >
              <span class="resource-number">0{index + 1}</span>
              <span class="resource-title">{resource.title}</span>
              <span class="resource-category">{resource.category}</span>
              <svg aria-hidden="true" viewBox="0 0 32 20"><path d="M1 10h27M20 2l8 8-8 8" /></svg>
            </a>
          ))}
        </div>

        <div class="reading-links">
          <a class="launch-link launch-link-blue dark-link" href="/resources">
            Browse all resources
            <svg aria-hidden="true" viewBox="0 0 28 18"><path d="M1 9h23M17 2l7 7-7 7" /></svg>
          </a>
          <a class="launch-link launch-link-red dark-link" href="/youtube">
            Watch on YouTube
            <svg aria-hidden="true" viewBox="0 0 28 18"><path d="M1 9h23M17 2l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
    </section>

    <section id="fit-check" class="print-dark final-launch-cta scroll-target">
      <div class="launch-shell final-cta-inner">
        <h2>Is Artist Systems a fit for your business?</h2>
        <p>The founding check takes about one minute. Your answers stay in your browser.</p>
        <div class="action-row final-actions">
          <a
            class="launch-button launch-button-primary"
            href="/artist-systems/qualify"
            data-track="true"
            data-track-event="tatassist_qualifier_started"
            data-track-label="Check founding fit"
            data-track-location="home_final_launch_cta"
            data-track-type="primary"
            data-track-destination="/artist-systems/qualify"
          >
            Check founding fit
            <svg aria-hidden="true" viewBox="0 0 28 18"><path d="M1 9h23M17 2l7 7-7 7" /></svg>
          </a>
          <a class="launch-link launch-link-blue" href="/toolkit">
            Review the full founding offer
            <svg aria-hidden="true" viewBox="0 0 28 18"><path d="M1 9h23M17 2l7 7-7 7" /></svg>
          </a>
        </div>
        <div class="final-facts">
          <span>Founding {artistSystemsConfig.foundingCapacity}</span>
          <span>Planned July 24–31</span>
          <span>U.S. working artists</span>
        </div>
      </div>
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body[data-page-type='artist_systems_home']) {
    background: #11110f;
  }

  :global(body[data-page-type='artist_systems_home'] nav) {
    border-bottom-color: rgb(192 57 43 / 0.55);
  }

  :global(body[data-page-type='artist_systems_home'] nav > div) {
    max-width: 82rem;
  }

  .launch-page {
    --ink: #11110f;
    --paper: #f5f0e8;
    --red: #c0392b;
    --blue: #2e86c1;
    --gold: #d4a843;
    --muted-dark: #565047;
    --muted-light: #c2b9a8;
    overflow: hidden;
  }

  .launch-shell {
    width: min(100% - 2rem, 82rem);
    margin-inline: auto;
  }

  .print-dark,
  .paper-section {
    position: relative;
    isolation: isolate;
  }

  .print-dark {
    color: var(--paper);
    background-color: var(--ink);
    background-image:
      radial-gradient(circle at 1px 1px, rgb(245 240 232 / 0.035) 1px, transparent 1.2px),
      linear-gradient(90deg, rgb(255 255 255 / 0.012), transparent 45%, rgb(255 255 255 / 0.012));
    background-size: 5px 5px, 100% 100%;
  }

  .paper-section {
    color: var(--ink);
    background-color: var(--paper);
    background-image:
      radial-gradient(circle at 1px 1px, rgb(17 17 15 / 0.07) 0.8px, transparent 1px),
      linear-gradient(92deg, rgb(192 57 43 / 0.018), transparent 38%, rgb(46 134 193 / 0.018));
    background-size: 6px 6px, 100% 100%;
  }

  .print-dark::after,
  .paper-section::after {
    content: '';
    position: absolute;
    z-index: 3;
    right: 0;
    bottom: 0;
    left: 0;
    height: 10px;
    background: linear-gradient(to bottom, var(--red) 0 45%, var(--ink) 45% 58%, var(--blue) 58% 100%);
  }

  h1,
  h2,
  h3,
  p {
    text-wrap: balance;
  }

  .launch-hero {
    min-height: 100svh;
    padding: 8.75rem 0 3rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(22rem, 0.85fr);
    gap: 2.75rem 4rem;
    align-items: center;
  }

  .hero-copy h1 {
    max-width: 12ch;
    margin: 0;
    color: var(--paper);
    font-size: clamp(4rem, 6.7vw, 6.75rem);
    font-weight: 700;
    letter-spacing: -0.038em;
    line-height: 0.92;
  }

  .hero-copy h1::after,
  .section-intro h2::after,
  .deposit-story h2::after,
  .founder-copy h2::after,
  .final-cta-inner h2::after {
    content: '';
    display: block;
    width: min(12rem, 40%);
    height: 4px;
    margin-top: 1rem;
    background: var(--red);
    transform: rotate(-1deg);
  }

  .hero-support {
    max-width: 39rem;
    margin: 1.65rem 0 1.75rem;
    color: var(--muted-light);
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    line-height: 1.55;
  }

  .action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem 1.5rem;
    align-items: center;
  }

  .launch-button,
  .launch-link {
    display: inline-flex;
    min-height: 3.6rem;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-weight: 700;
    text-decoration: none;
    transition: color 160ms ease, background-color 160ms ease, border-color 160ms ease, transform 160ms ease;
  }

  .launch-button svg,
  .launch-link svg,
  .resource-row svg {
    width: 1.65rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: square;
    stroke-linejoin: miter;
    stroke-width: 2;
  }

  .launch-button-primary {
    min-width: 14rem;
    padding: 0.9rem 1.25rem;
    border: 1px solid #ef6a59;
    border-radius: 2px;
    color: white;
    background: var(--red);
    box-shadow: inset 0 0 0 1px rgb(17 17 15 / 0.35);
  }

  .launch-button-primary:hover {
    background: #a93125;
    transform: translateY(-2px);
  }

  .launch-link {
    padding: 0.5rem 0;
    border-bottom: 2px solid currentColor;
  }

  .launch-link-blue {
    color: #58a9da;
  }

  .launch-link-red {
    color: var(--red);
  }

  .launch-link:hover {
    color: var(--paper);
    transform: translateX(3px);
  }

  .launch-button:focus-visible,
  .launch-link:focus-visible,
  .resource-row:focus-visible,
  .comparison-link:focus-visible {
    outline: 3px solid var(--gold);
    outline-offset: 4px;
  }

  .credibility-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1.2rem;
    margin-top: 1.55rem;
    color: var(--paper);
    font-size: 0.92rem;
  }

  .credibility-line span {
    display: inline-flex;
    align-items: center;
    gap: 1.2rem;
  }

  .credibility-line span:not(:last-child)::after {
    content: '';
    width: 0.42rem;
    height: 0.42rem;
    background: var(--gold);
    transform: rotate(45deg);
  }

  .founding-panel {
    position: relative;
    padding: 0.25rem 0 0.25rem 2.25rem;
    border-left: 2px solid var(--blue);
  }

  .founding-title {
    margin: 0 0 1rem;
    color: var(--gold);
    font-family: var(--font-heading);
    font-size: clamp(3rem, 5.2vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1;
    text-transform: uppercase;
  }

  .founding-title strong {
    color: var(--red);
  }

  .founding-panel dl {
    margin: 0;
    border-top: 2px solid rgb(46 134 193 / 0.65);
  }

  .founding-panel dl > div {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: baseline;
    padding: 0.9rem 0;
    border-bottom: 1px solid rgb(46 134 193 / 0.6);
  }

  .founding-panel dt {
    color: var(--muted-light);
    font-size: 0.92rem;
  }

  .founding-panel dd {
    margin: 0;
    color: var(--paper);
    font-weight: 700;
    text-align: right;
  }

  .flow-line {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 3.4rem minmax(0, 1fr) 3.4rem minmax(0, 1.55fr) 3.4rem minmax(0, 0.75fr);
    gap: 0.75rem;
    align-items: center;
    padding-top: 1.25rem;
    border-top: 1px solid rgb(46 134 193 / 0.65);
  }

  .flow-step {
    padding: 0 0 0.55rem;
    border-bottom: 4px solid;
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 2.6vw, 2.5rem);
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
  }

  .flow-step-1,
  .flow-step-4 {
    border-color: var(--red);
  }

  .flow-step-2 {
    border-color: var(--blue);
  }

  .flow-step-3 {
    border-color: var(--gold);
  }

  .flow-arrow,
  .engine-bridge svg,

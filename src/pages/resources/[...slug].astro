---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('resources');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  category={article.data.category}
  quickTake={article.data.quickTake}
  primaryCTA={article.data.primaryCTA}
  secondaryCTA={article.data.secondaryCTA}
  ctaBridge={article.data.ctaBridge}
  publishDate={article.data.publishDate}
  updatedDate={article.data.updatedDate}
  faqs={article.data.faqs}
  relatedArticles={article.data.relatedArticles}
>
  <Content />
</ArticleLayout>

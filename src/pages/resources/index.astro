---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { resourceCategories } from '../../data/site';

const allArticles = await getCollection('resources');

const featured = allArticles.filter((a) => a.data.featured);
---

<BaseLayout
  title="Resources — Tattoo Business Education"
  description="Practical tattoo business resources for pricing, deposits, client qualification, and professional systems. By artists, for artists since 2008."
  ogImage="/og/tatassist-resources.png"
  pageType="resources_hub"
>
  <Nav slot="header" />

  <!-- Hero -->
  <section class="pt-28 sm:pt-36 pb-12 sm:pb-16 bg-brand-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-brand-cream leading-tight mb-4">
        Tattoo business resources for artists who want better pricing, stronger deposits, and more control.
      </h1>
      <p class="text-lg text-brand-text-muted max-w-2xl mx-auto">
        Practical articles, stories, and strategy from artists who've lived the business side of tattooing through real industry highs and lows.
      </p>
    </div>
  </section>

  <!-- Browse by Category -->
  <section class="py-12 sm:py-16 bg-brand-dark-lighter border-y border-white/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-heading font-bold text-brand-cream mb-8">Browse by topic</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        {resourceCategories.map((cat) => {
          const catArticles = allArticles.filter((a) => a.data.category === cat.slug);
          return (
            <a href={`/resources/${cat.slug}`} class="group bg-brand-dark border border-white/10 hover:border-brand-gold/30 rounded-xl p-6 transition-all block">
              <h3 class="text-xl font-heading font-bold text-brand-cream group-hover:text-brand-gold transition-colors mb-2">
                {cat.label}
              </h3>
              <p class="text-brand-text-muted text-sm leading-relaxed mb-4">{cat.description}</p>
              <div class="flex items-center justify-between">
                <span class="text-xs text-brand-text-muted/60">{catArticles.length} article{catArticles.length !== 1 ? 's' : ''}</span>
                <span class="text-brand-gold text-sm font-medium group-hover:translate-x-1 transition-transform">Explore &rarr;</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Featured Resources -->
  <section class="py-12 sm:py-16 bg-brand-dark">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-heading font-bold text-brand-cream mb-8">Featured resources</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {featured.map((article) => {
          const catLabel = resourceCategories.find((c) => c.slug === article.data.category)?.label || article.data.category;
          return (
            <a href={`/resources/${article.id}`} class="group bg-brand-dark-lighter border border-white/10 hover:border-brand-gold/20 rounded-xl p-6 sm:p-8 transition-colors block">
              <span class="text-xs font-semibold uppercase tracking-wider text-brand-gold/70 mb-3 block">{catLabel}</span>
              <h3 class="text-lg sm:text-xl font-heading font-bold text-brand-cream group-hover:text-brand-gold transition-colors mb-3 leading-snug">
                {article.data.title}
              </h3>
              <p class="text-brand-text-muted text-sm leading-relaxed">{article.data.description}</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- All Articles -->
  <section class="py-12 sm:py-16 bg-brand-dark-lighter">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-heading font-bold text-brand-cream mb-8">All resources</h2>
      <div class="space-y-4">
        {allArticles.map((article) => {
          const catLabel = resourceCategories.find((c) => c.slug === article.data.category)?.label || article.data.category;
          return (
            <a href={`/resources/${article.id}`} class="group flex items-start gap-4 bg-brand-dark border border-white/10 hover:border-brand-gold/20 rounded-xl p-5 sm:p-6 transition-colors block">
              <div class="flex-1">
                <span class="text-xs font-semibold uppercase tracking-wider text-brand-gold/70 mb-1 block">{catLabel}</span>
                <h3 class="text-base sm:text-lg font-heading font-bold text-brand-cream group-hover:text-brand-gold transition-colors leading-snug">
                  {article.data.title}
                </h3>
              </div>
              <span class="text-brand-gold/50 group-hover:text-brand-gold text-sm mt-1 shrink-0 transition-colors">&rarr;</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-red-dark py-12 sm:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl sm:text-3xl font-heading font-bold text-white mb-4">
        Ready to put the knowledge to work?
      </h2>
      <p class="text-white/80 mb-8">Tools and systems that turn what you've learned into real business improvements.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/calculator"
          class="inline-flex items-center px-8 py-3.5 bg-white text-brand-dark font-semibold rounded-lg hover:bg-brand-cream transition-colors"
          data-track="true"
          data-track-event="tatassist_cta_click"
          data-track-label="See the Calculator"
          data-track-location="resources_hub_final_cta"
          data-track-type="primary"
          data-track-destination="/calculator"
        >
          See the Calculator
        </a>
        <a
          href="/toolkit"
          class="inline-flex items-center px-8 py-3.5 border border-white/40 text-white hover:bg-white/10 font-medium rounded-lg transition-colors"
          data-track="true"
          data-track-event="tatassist_cta_click"
          data-track-label="Explore Artist Systems"
          data-track-location="resources_hub_final_cta"
          data-track-type="secondary"
          data-track-destination="/toolkit"
        >
          Explore Artist Systems
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

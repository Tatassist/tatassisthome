---
interface Props {
  title: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
  trackingLocation?: string;
  trackingEvent?: string;
}

const {
  title,
  description,
  ctaLabel,
  ctaHref,
  trackingLocation = 'solution_pillar',
  trackingEvent = 'tatassist_cta_click',
} = Astro.props;
---

<div class="text-center sm:text-left">
  <h3 class="text-xl font-heading font-bold text-brand-cream mb-3">{title}</h3>
  <p class="text-brand-text-muted text-sm leading-relaxed mb-4">{description}</p>
  <a
    href={ctaHref}
    class="text-brand-gold hover:text-brand-gold/80 text-sm font-medium transition-colors"
    data-track="true"
    data-track-event={trackingEvent}
    data-track-label={ctaLabel}
    data-track-location={trackingLocation}
    data-track-type="supporting_link"
    data-track-destination={ctaHref}
  >
    {ctaLabel} &rarr;
  </a>
</div>
